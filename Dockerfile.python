FROM python:3.11-slim

WORKDIR /app

# Install twin-protocol
COPY pyproject.toml README.md twins_mcp_bridge.py ./
COPY src/ ./src/
RUN pip install --no-cache-dir -e ".[test]"

# Expose Twins HTTP transport port
EXPOSE 3743

# Default: start Twins HTTP server
CMD ["python", "-m", "twin_protocol.transport", "--serve", "--port", "3743"]
